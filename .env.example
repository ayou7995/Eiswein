# Eiswein Environment Variables Template
#
# SECURITY: In production, this file is NOT used directly.
# Secrets are stored encrypted via SOPS + age in secrets/eiswein.enc.yaml
# The docker-entrypoint.sh decrypts and injects env vars at container start.
#
# This template exists for local development. Copy to .env for local work.
# NEVER commit .env. NEVER put production secrets here.

# === Security (REQUIRED) ===
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your_jwt_secret_here_at_least_64_chars

# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your_encryption_key_here_32_bytes_base64

# Admin user (seeded on first startup if users table is empty)
ADMIN_USERNAME=admin
# bcrypt-hashed password (12 rounds). Min 16 chars or passphrase format.
# Generate: python scripts/set_password.py  (uses zxcvbn to reject weak)
ADMIN_PASSWORD_HASH=$2b$12$...

# === Environment ===
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/eiswein.db

# === Data Sources ===
# FRED API (free, required for macro data): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Schwab API (optional, user has account)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Polygon.io (optional, production paid tier)
POLYGON_API_KEY=

# === Email Notifications ===
# Gmail App Password or SendGrid API Key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=eiswein@yourdomain.com
EMAIL_TO=your-email@gmail.com

# === CORS / URLs ===
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# === Rate Limiting ===
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=60/minute
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
